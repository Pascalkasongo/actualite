<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AcadémiaNews</title>
    <link rel="stylesheet" href="{{ asset('build/app.css') }}">
</head>

<body class="bg-gray-50 text-gray-900">

<header class="sticky top-0 z-50 border-b border-red-700/20 bg-red-600/95 backdrop-blur shadow-sm">
    <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">

            {# Logo #}
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-white font-bold text-xl tracking-tight">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/15 ring-1 ring-white/20">
                    A
                </span>
                <span>Théologie Actualité</span>
            </a>

            {# Desktop menu #}
            <div class="hidden md:flex md:items-center md:gap-8">
                <a href="{{ path('app_home') }}"
                   class="text-white/90 font-medium transition hover:text-white">
                    Accueil
                </a>

                {% if app.user and is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_actualite_index') }}"
                       class="text-white/90 font-medium transition hover:text-white">
                        Actualités
                    </a>
                {% endif %}

                {# Dropdown Formation #}
                <div class="relative">
                    <button
                        id="formation-btn"
                        type="button"
                        class="inline-flex items-center gap-2 text-white/90 font-medium transition hover:text-white focus:outline-none"
                        aria-expanded="false"
                        aria-controls="formation-dropdown"
                    >
                        Formation
                        <svg id="formation-arrow"
                             class="h-4 w-4 transition-transform duration-200"
                             fill="none"
                             stroke="currentColor"
                             viewBox="0 0 24 24"
                             aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <div id="formation-dropdown"
                         class="absolute left-0 mt-3 w-52 overflow-hidden rounded-xl bg-white py-2 shadow-lg ring-1 ring-black/5 hidden">
                        <a href="{{ path('app_enseignant') }}"
                           class="block px-4 py-2.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50 hover:text-red-600">
                            Enseignants
                        </a>
                        <a href="#"
                           class="block px-4 py-2.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50 hover:text-red-600">
                            Étudiants
                        </a>
                    </div>
                </div>

                <a href="https://bibliotheque-udbl.org/pmb/opac_css/"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="text-white/90 font-medium transition hover:text-white">
                    Bibliothèque
                </a>

                <a href="{{ path('app_apropos') }}"
                   class="text-white/90 font-medium transition hover:text-white">
                    À propos
                </a>
            </div>

            {# Mobile button #}
            <button
                id="mobile-menu-button"
                type="button"
                class="inline-flex items-center justify-center rounded-lg p-2 text-white transition hover:bg-white/10 md:hidden"
                aria-expanded="false"
                aria-controls="mobile-menu"
            >
                <span class="sr-only">Ouvrir le menu</span>
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>

        {# Mobile menu #}
        <div id="mobile-menu" class="md:hidden hidden pb-4">
            <div class="mt-2 space-y-1 rounded-2xl bg-white/10 p-2 ring-1 ring-white/10">
                <a href="{{ path('app_home') }}"
                   class="block rounded-xl px-3 py-2 text-white font-medium transition hover:bg-white/10">
                    Accueil
                </a>

                {% if app.user and is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_actualite_index') }}"
                       class="block rounded-xl px-3 py-2 text-white font-medium transition hover:bg-white/10">
                        Actualités
                    </a>
                {% endif %}

                {# Mobile Formation dropdown #}
                <div>
                    <button
                        id="mobile-formation-btn"
                        type="button"
                        class="flex w-full items-center justify-between rounded-xl px-3 py-2 text-left text-white font-medium transition hover:bg-white/10"
                        aria-expanded="false"
                        aria-controls="mobile-formation-dropdown"
                    >
                        <span>Formation</span>
                        <svg id="mobile-formation-arrow"
                             class="h-4 w-4 transition-transform duration-200"
                             fill="none"
                             stroke="currentColor"
                             viewBox="0 0 24 24"
                             aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <div id="mobile-formation-dropdown" class="mt-1 hidden space-y-1 pl-3">
                        <a href="{{ path('app_enseignant') }}"
                           class="block rounded-xl px-3 py-2 text-sm text-white/90 transition hover:bg-white/10 hover:text-white">
                            Enseignants
                        </a>
                        <a href="#"
                           class="block rounded-xl px-3 py-2 text-sm text-white/90 transition hover:bg-white/10 hover:text-white">
                            Étudiants
                        </a>
                    </div>
                </div>

                <a href="https://bibliotheque-udbl.org/pmb/opac_css/"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="block rounded-xl px-3 py-2 text-white font-medium transition hover:bg-white/10">
                    Bibliothèque
                </a>

                <a href="{{ path('app_apropos') }}"
                   class="block rounded-xl px-3 py-2 text-white font-medium transition hover:bg-white/10">
                    À propos
                </a>
            </div>
        </div>
    </nav>
</header>

