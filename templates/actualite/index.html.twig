{% include  'base.html.twig' %}
<!-- CONTENU PRINCIPAL -->
<main class="max-w-7xl mx-auto px-4 py-10">

<h1 class="text-3xl font-bold mb-8 text-gray-800">
Actualités
</h1>
<div class="mb-8">
    <a href="{{ path('app_actualite_new') }}"
       class="inline-block bg-red-600 text-white px-5 py-2 rounded-lg shadow hover:bg-red-700 transition">
      Publier une actualité
    </a>
</div>

<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

{% for actualite in actualites %}

<article class="bg-white rounded-xl shadow hover:shadow-lg transition overflow-hidden">

    {% if actualite.cover %}
        <img 
            src="{{ asset('uploads/' ~ actualite.cover) }}"
            alt="Actualité"
            class="w-full h-48 object-cover">
    {% endif %}

    <div class="p-6">

        <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-2 leading-tight">
            {{ actualite.theme }}
        </h2>

        <!-- Sous-thème -->
        <h3 class="text-md sm:text-lg text-gray-500 font-medium mb-4">
            {{ actualite.sousTheme }}
        </h3>
        <p class="text-gray-700 mb-4">
            {{ actualite.contenu|slice(0,50) }}...
        </p>
        <div class="flex items-center gap-4 mt-4">

    <!-- Lire plus -->
    <a href="{{ path('app_actualite_show', {
            id: actualite.id,
            theme: actualite.theme|lower|replace({' ':'-'}),
            sousTheme: actualite.sousTheme|lower|replace({' ':'-'})
        }) }}"
        class="px-4 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition shadow-md">
        Lire plus
    </a>

    <!-- Modifier -->
    <a href="{{ path('app_actualite_edit', {'id': actualite.id}) }}"
       class="px-4 py-2 bg-yellow-400 text-white rounded-lg font-semibold hover:bg-yellow-500 transition shadow-md">
        Modifier
    </a>

    <!-- Supprimer -->
    <form method="post"
          action="{{ path('app_actualite_delete', {'id': actualite.id}) }}"
          onsubmit="return confirm('Voulez-vous vraiment supprimer cette actualité ?');"
          class="inline">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ actualite.id) }}">
        <button type="submit"
                class="px-4 py-2 bg-gray-200 text-red-600 rounded-lg font-semibold hover:bg-red-100 hover:text-red-700 transition shadow-md">
            Supprimer
        </button>
    </form>

</div>  

    </div>

</article>

{% else %}

<p class="text-gray-500">Aucune actualité disponible.</p>

{% endfor %}

</div>

</main>

{% include  'footer.html.twig' %}