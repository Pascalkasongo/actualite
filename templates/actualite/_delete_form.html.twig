<form method="post" action="{{ path('app_actualite_delete', {'id': actualite.id}) }}" 
      onsubmit="return confirm('Are you sure you want to delete this item?');">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ actualite.id) }}">

    <button class="btn text-red-600 font-semibold hover:underline">
        Delete
    </button>

</form>