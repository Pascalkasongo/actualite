{% include 'base.html.twig' %}

<main class="max-w-6xl mx-auto px-4 py-10">

{% block body %}

<div class="bg-white shadow-xl rounded-2xl p-8">

<div class="flex justify-between items-center mb-8">

<h1 class="text-3xl font-bold text-gray-800">
Enseignants {{ "now"|date("Y") -1 }} - {{ "now"|date("Y") }}
</h1>

{% if app.user and is_granted('ROLE_ADMIN') %}
<a href="{{ path('app_actualite_new') }}"
class="bg-red-600 text-white px-5 py-2 rounded-lg hover:bg-red-700 transition shadow">
+ Ajouter
</a>
{% endif %}

</div>


<div class="overflow-x-auto">

<table class="min-w-full divide-y divide-gray-200">

<thead class="bg-gray-50 sticky top-0">
<tr class="text-xs font-semibold text-gray-600 uppercase">

<th class="px-6 py-4 text-left">Nom</th>

<th class="px-6 py-4 text-left">Diplôme</th>

<th class="px-6 py-4 text-left">Université</th>

<th class="px-6 py-4 text-left">Contact</th>

</tr>
</thead>

<tbody class="divide-y divide-gray-100">

{% for enseignant in enseignants %}

<tr class="hover:bg-gray-50 transition">

<td class="px-6 py-4 font-semibold text-gray-800">
{{ enseignant.nom }}
</td>


<td class="px-6 py-4">

<span class="bg-blue-100 text-blue-700 text-xs font-medium px-3 py-1 rounded-full">
{{ enseignant.diplome }}
</span>

</td>


<td class="px-6 py-4 text-gray-600">
{{ enseignant.universite }}
</td>


<td class="px-6 py-4 text-sm">

<div class="flex flex-col gap-1">

<a href="tel:{{ enseignant.telephone }}"
class="text-gray-700 hover:text-black">
 {{ enseignant.telephone }}
</a>

<a href="mailto:{{ enseignant.email }}"
class="text-blue-600 hover:underline">
{{ enseignant.email }}
</a>

</div>

</td>


</div>

</td>

</tr>

{% else %}

<tr>
<td colspan="5" class="text-center py-10 text-gray-400">
Aucun enseignant enregistré
</td>
</tr>

{% endfor %}

</tbody>

</table>

</div>

</div>

{% endblock %}

</main>

{% include 'footer.html.twig' %}